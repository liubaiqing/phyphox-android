<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_surface"
    tools:context=".ExperimentList.ExperimentListActivity"
    android:id="@+id/rootExperimentList">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/expListHeader"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/button_background"
        android:elevation="4dp"
        android:fitsSystemWindows="true"
        app:title="Gyroscope"
        app:titleTextColor="@color/button_text_color"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="Gyroscope"
            android:textSize="20sp"
            android:textColor="@color/button_text_color"
            android:fontFamily="sans-serif-medium"/>

        <ImageView
            android:id="@+id/credits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:padding="8dp"
            android:background="@drawable/rounded_button"
            app:tint="@color/button_text_color"
            app:srcCompat="@drawable/info"
            android:contentDescription="@string/info"/>

    </androidx.appcompat.widget.Toolbar>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_secondary_container"/>

    <de.rwth_aachen.phyphox.Helper.ReportingScrollView
        android:id="@+id/experimentScroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/experimentList"
            android:clipChildren="true"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"/>

    </de.rwth_aachen.phyphox.Helper.ReportingScrollView>

    <View
        android:id="@+id/experimentListDimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        android:background="@color/phyphox_black_60"/>

</LinearLayout>
