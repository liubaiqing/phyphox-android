<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="Theme.Phyphox" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:textColor">@color/phyphox_black_100</item>
        <item name="android:textColorPrimary">@color/phyphox_black_100</item>
        <item name="android:textColorSecondary">@color/phyphox_black_40</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="android:colorAccent" tools:ignore="NewApi">@color/accent_color</item>
        <item name="android:textColorHighlight">@color/highlight_color</item>
        <item name="backgroundColor">@color/phyphox_white_100</item>
        <item name="colorPrimary">@color/button_background</item>
        <item name="colorPrimaryDark">@color/button_pressed_color</item>
        <item name="colorOnPrimary">@color/button_text_color</item>
        <item name="colorSecondary">@color/accent_color</item>
        <item name="colorSurface">@color/phyphox_white_100</item>
        <item name="colorOnSurface">@color/phyphox_black_100</item>
        <item name="android:textSize">@dimen/font</item>

        <item name="android:itemBackground">@color/phyphox_white_100</item>
        
        <item name="tint">@color/button_background</item>

        <item name="android:windowBackground">@color/phyphox_white_100</item>

        <item name="textAppearanceLabelSmall">@style/TextAppearance.Phyphox.Small</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Phyphox.Medium</item>

        <item name="alertDialogTheme">@style/Theme.Phyphox.Dialog.Alert.Light</item>
        <item name="dialogTheme">@style/Theme.Phyphox.Dialog.Alert.Light</item>

        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Phyphox.Light</item>

        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>

        <!-- Android 12+ splash screen settings -->
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenBrandingImage">@null</item>
        <item name="android:windowSplashScreenBackground">@color/phyphox_white_100</item>

    </style>

    <style name="rwth" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:textColor">@color/phyphox_black_100</item>
        <item name="colorPrimary">@color/button_background</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="alertDialogTheme">@style/rwthDialog</item>
    </style>


    <style name="Widget.Phyphox.Light" parent="Theme.Phyphox">
        <item name="android:textColor">@color/phyphox_black_100</item>
        <item name="tint">@color/phyphox_black_100</item>
        <item name="android:tint">@color/phyphox_black_100</item>
    </style>

    <style name="support_phyphox_hint_root" parent="Theme.Phyphox">
        <item name="backgroundColor">@color/phyphox_white_80</item>
    </style>

    <style name="Widget.Phyphox.BottomNavigationView" parent="Widget.Phyphox.Light">
        <item name="android:color">@color/phyphox_primary</item>
    </style>

    <style name="SliderMaterialTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/phyphox_primary</item>
    </style>

    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetDialog.Light</item>
    </style>

</resources>
