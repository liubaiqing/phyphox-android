<?xml version="1.0" encoding="utf-8"?>

<resources xmlns:android="http://schemas.android.com/apk/res/android">



    <style name="Theme.Phyphox.Dialog.Alert.Light" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="textColorAlertDialogListItem">@color/phyphox_black_100</item>
        <item name="colorAccent">@color/phyphox_primary</item>
        <item name="android:colorBackground">@color/phyphox_white_100</item>
    </style>

    <style name="Theme.Phyphox.Dialog.Alert.Dark" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="textColorAlertDialogListItem">@color/phyphox_white_100</item>
        <item name="colorAccent">@color/phyphox_primary</item>
        <item name="android:colorBackground">@color/phyphox_black_60</item>
    </style>

    <style name="rwthDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">@color/phyphox_rwth_primary</item>
    </style>

    <style name="BottomNavigationView" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">@dimen/graph_tools_font</item>
    </style>

    <style name="BottomNavigationView.Active" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">@dimen/graph_tools_font</item>
    </style>

    <style name="PreferenceThemeOverlay.v14.Phyphox.Dark" parent="PreferenceThemeOverlay.v14">
        <item name="android:tint">@color/phyphox_white_100</item>
    </style>

    <style name="PreferenceThemeOverlay.v14.Phyphox.Light" parent="PreferenceThemeOverlay.v14">
        <item name="android:tint">@color/phyphox_black_100</item>
    </style>

    <style name="MaterialButtonTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/phyphox_black_100</item>
        <item name="android:textColor">@color/phyphox_white_100</item>

    </style>

    <style name="BottomSheetDialog.Light" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@color/phyphox_white_100</item>
        <item name="android:textColor">@color/phyphox_black_60</item>
    </style>

    <style name="BottomSheetDialog.Dark" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/phyphox_black_40</item>
        <item name="android:textColor">@color/phyphox_white_100</item>
    </style>

</resources>
